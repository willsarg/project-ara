{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ara.dev/wire/work.response.json",
  "title": "Work dispatch (server → node)",
  "description": "200 job offer from GET /api/work?wait=N. The node must durably journal it and POST /api/work/{id}/ack before execution. An unacknowledged offer expires and may be reoffered; a 204 has no body.",
  "type": "object",
  "properties": {
    "job": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["run", "characterize", "detect", "benchmark"] },
        "args": {
          "type": "object",
          "properties": {
            "engine": { "type": "string" },
            "target_authority": {
              "type": "string",
              "pattern": "^node-target:v1:[0-9a-f]{64}$"
            }
          },
          "additionalProperties": true
        }
      },
      "required": ["id", "kind", "args"],
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": { "enum": ["run", "benchmark"] },
              "args": {
                "properties": { "engine": { "const": "ollama" } },
                "required": ["engine"]
              }
            },
            "required": ["kind", "args"]
          },
          "then": { "properties": { "args": { "required": ["target_authority"] } } }
        }
      ],
      "additionalProperties": false
    }
  },
  "required": ["job"],
  "additionalProperties": false
}
